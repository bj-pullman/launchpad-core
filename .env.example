# ============================================================
# Launchpad Environment
# ============================================================

LAUNCHPAD_ENV=dev
SYSTEM_TIMEZONE=America/Chicago

# ============================================================
# Security
# ============================================================

SECRET_KEY=replace_with_secret_key

# ============================================================
# Snipe-IT API / Now stored in DB
# ============================================================



# ============================================================
# Google SSO
# ============================================================

GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=

# Optional Google Directory settings
# GOOGLE_DIRECTORY_SERVICE_ACCOUNT_FILE=
# GOOGLE_DIRECTORY_DELEGATED_ADMIN=

# ============================================================
# Auth Behavior
# ============================================================

AUTH_ALLOWED_DOMAINS=example.org
AUTH_REQUIRE_GOOGLE_HOSTED_DOMAIN=true
AUTH_AUTO_PROVISION=false
AUTH_DEFAULT_ROLE=viewer

# Optional auth behavior
# AUTH_REQUIRE_LOGIN_FOR_LAUNCHPAD=false
# AUTH_REQUIRED_GROUPS=staff@example.org
# AUTH_GROUP_MATCH_MODE=any

# ============================================================
# Session Settings
# ============================================================

SESSION_IDLE_TIMEOUT_MINUTES=10
SESSION_ABSOLUTE_TIMEOUT_HOURS=8
SESSION_REMEMBER_ME_DAYS=0

# Cookie Security
SESSION_COOKIE_NAME=launchpad_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ============================================================
# Optional Bootstrap / Overrides
# ============================================================

# BOOTSTRAP_ADMIN_EMAIL=admin@example.org

# Optional database overrides
# IMPORT_BY_SCAN_DB_PATH=instance/import_by_scan/data/import_by_scan.db
# SNIPE_CATALOG_DB_PATH=instance/snipe_catalog/data/snipe_catalog.db